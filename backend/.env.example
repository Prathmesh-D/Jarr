# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/jarr_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=jarr_user
DB_PASSWORD=jarr_pass

# JWT Configuration (At least 256-bit secure secret in production)
JWT_SECRET=your_super_secret_jwt_key_that_is_at_least_256_bits_long
JWT_EXPIRATION_MS=86400000

# Google OAuth2 Client ID
GOOGLE_CLIENT_ID=your_google_client_id

# Mail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Frontend URL for CORS
FRONTEND_URL=https://jarr.app
